{
  "expo": {
    "name": "FaceMetrics AI",
    "slug": "facemetrics-ai",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "facemetrics",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.facemetrics.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FaceMetrics AI benötigt die Kamera für die Gesichtsanalyse.",
        "NSPhotoLibraryUsageDescription": "FaceMetrics AI benötigt Fotos für die Gesichtsanalyse."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07080A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "package": "ai.facemetrics.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "FaceMetrics AI",
      "shortName": "FaceMetrics",
      "description": "Premium Gesichtsanalyse für Symmetrie, Proportionen und Landmarken.",
      "themeColor": "#07080A",
      "backgroundColor": "#07080A",
      "lang": "de"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07080A",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FaceMetrics AI benötigt Fotos für die Gesichtsanalyse.",
          "cameraPermission": "FaceMetrics AI benötigt die Kamera für die Gesichtsanalyse."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
